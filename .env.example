# ==============================================================================
# [PROJECT_NAME] — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in real values.
#
#   cp .env.example .env
#
# NEVER commit .env to git. It is gitignored.
# Keep THIS file (.env.example) up to date whenever you add a new variable.
# Use descriptive placeholders — never real values.
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Full connection string (preferred) or individual parts
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=dbname
# DATABASE_USER=user
# DATABASE_PASSWORD=password

# ── Authentication ────────────────────────────────────────────────────────────
# Must be at least 32 characters, randomly generated
JWT_SECRET=your-jwt-secret-minimum-32-characters-here
JWT_EXPIRES_IN=7d

# ── External Services ─────────────────────────────────────────────────────────
# Uncomment and fill in as needed

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# SENDGRID_API_KEY=SG....
# SENDGRID_FROM_EMAIL=no-reply@example.com

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=my-bucket

# REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
