# auth-api environment template (EXAMPLE)
#
# In a real project: copy to `auth-api/.env` and fill in real values.
# `.env` is gitignored — never commit it.
# See ../../.ai/credentials.md#env-file-convention for the rules.

# --- HTTP server ---
AUTH_API_PORT=4001
AUTH_API_LOG_LEVEL=info

# --- JWT ---
JWT_SECRET=                       # required; HS256 signing secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Postgres (shared cluster, dedicated role) ---
AUTH_DATABASE_URL=                # postgres://auth_user:...@host:5432/app

# --- Redis (session blacklist) ---
AUTH_REDIS_URL=                   # redis://localhost:6379/0

# --- Email (password resets) ---
SENDGRID_API_KEY=
PASSWORD_RESET_FROM_EMAIL=
