# .example-module environment template
#
# Copy this file to `.example-module/.env` and fill in real values.
# `.env` is gitignored — never commit it.
# See ../.ai/credentials.md#env-file-convention for the rules.

# --- Module-specific runtime config ---
# EXAMPLE_MODULE_PORT=3000
# EXAMPLE_MODULE_LOG_LEVEL=info

# --- External services (placeholders only) ---
# EXAMPLE_API_KEY=
# EXAMPLE_DATABASE_URL=
