#!/bin/sh
# pre-commit — Git pre-commit hook
#
# Checks for:
#   1. .env files accidentally staged
#   2. Credential leak patterns (actual secrets in staged files)
#
# Activated by running the installer once per clone:
#   bash  .github/hooks/install-hooks.sh    # macOS / Linux / WSL / Git Bash
#   pwsh  .github/hooks/install-hooks.ps1   # Windows PowerShell
#
# Both installers set `git config core.hooksPath .github/hooks`, so this file
# runs in place — no copying, no .sample suffix.
#
# To make credential-pattern hits a HARD BLOCK instead of a warning,
# change the SINGLE `exit 0` line at the end of the credential-scan block
# (clearly marked below) to `exit 1`.

set -e

echo "[pre-commit] Running safety checks..."

# ── 1. Block staged .env files ──────────────────────────────────────────────
STAGED_ENV=$(git diff --cached --name-only -z | tr '\0' '\n' | grep -E '(^|/)\.env(\.|$)' | grep -v '\.example$' || true)
if [ -n "$STAGED_ENV" ]; then
  echo ""
  echo "  BLOCKED: Credential file(s) staged for commit:"
  echo "$STAGED_ENV" | sed 's/^/    /'
  echo ""
  echo "  .env files must never be committed. Add them to .gitignore."
  echo "  See: .ai/credentials.md#gitignore-requirements"
  echo ""
  exit 1
fi

# ── 2. Scan staged files for common credential patterns ─────────────────────
# Use NUL-delimited paths so filenames with spaces or special chars are safe.
STAGED_FILES=$(git diff --cached --name-only -z --diff-filter=ACM | tr '\0' '\n' | grep -v '\.example$' || true)

if [ -n "$STAGED_FILES" ]; then
  # Pattern 1: known provider key prefixes (high-confidence, low false-positive rate)
  HITS1=$(printf '%s\n' "$STAGED_FILES" | tr '\n' '\0' | xargs -0 -r grep -Eln \
    'sk_live_|pk_live_|BEGIN (RSA|EC|OPENSSH) PRIVATE KEY|AKIA[0-9A-Z]{16}' \
    2>/dev/null || true)

  # Pattern 2: env-style assignment with a high-entropy value (uppercase key names only,
  # value must be 16+ alphanumeric chars — avoids matching source code assignments)
  HITS2=$(printf '%s\n' "$STAGED_FILES" | tr '\n' '\0' | xargs -0 -r grep -Eln \
    '^(PASSWORD|SECRET|API_KEY|PRIVATE_KEY|TOKEN|CLIENT_SECRET)[[:space:]]*=[[:space:]]*[A-Za-z0-9+/]{16,}' \
    2>/dev/null || true)
  HITS=$(printf '%s\n%s' "$HITS1" "$HITS2" | sort -u | grep -v '^$' || true)

  if [ -n "$HITS" ]; then
    echo ""
    echo "  WARNING: Possible credential pattern detected in staged files:"
    echo "$HITS" | sed 's/^/    /'
    echo ""
    echo "  Review these files before committing."
    echo "  If these are false positives, use: git commit --no-verify"
    echo "  See: .ai/credentials.md#never-commit-credentials"
    echo ""
    # ── HARD-BLOCK TOGGLE ─────────────────────────────────────────────────
    # Change the next line to `exit 1` to make credential pattern hits fail the commit.
    exit 0
    # ──────────────────────────────────────────────────────────────────────
  fi
fi

echo "[pre-commit] All checks passed."
exit 0
